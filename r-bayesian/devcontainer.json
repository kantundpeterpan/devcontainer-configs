{
  "name": "R Bayesian DevContainer",
  "image": "ghcr.io/${localEnv:GHCR_USERNAME:-yourusername}/devcontainer-base-images/r-bayesian:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "REditorSupport.r-lsp",
        "Ikuyadeu.r",
        "RDebugger.r-debugger",
        "quarto.quarto",
        "openchamber.openchamber",
        "github.vscode-github-actions",
        "sanjulaganepola.github-local-actions"
      ],
      "settings": {
        "r.rterm.linux": "/usr/local/bin/radian",
        "r.bracketedPaste": true,
        "r.sessionWatcher": true,
        "r.plot.useHttpgd": true,
        "r.lsp.debug": false,
        "r.lsp.diagnostics": true,
        "r.path": "/opt/conda/envs/r-bayesian/bin/R"
      }
    },
    "devpod": {
      "prebuildRepository": "ghcr.io/${localEnv:GHCR_USERNAME:-yourusername}/devpod-cache"
    }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/opencode:1": {},
    "ghcr.io/devcontainers/features/quarto-cli:1": {}
  },
  "forwardPorts": [8888, 8787],
  "portsAttributes": {
    "8888": {
      "label": "Jupyter Lab",
      "onAutoForward": "openBrowser"
    },
    "8787": {
      "label": "RStudio Server",
      "onAutoForward": "notify"
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/opencode,target=/home/vscode/.config/opencode,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/gcloud,target=/home/vscode/.config/gcloud,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],
  "postStartCommand": "if [ -d ~/.ssh ]; then chmod 700 ~/.ssh && chmod 600 ~/.ssh/*; fi"
}
